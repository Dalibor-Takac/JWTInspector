<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JWTInspector2.MainPage"
             xmlns:vm="clr-namespace:JWTInspector2.ViewModels"
             xmlns:v="clr-namespace:JWTInspector2.Views"
             x:DataType="vm:MainPageViewModel">
    <ScrollView>
        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Entry Placeholder="Enter or paste token here to begin..."
                   Text="{Binding TokenText}"
                   Margin="0,0,0,4"
                   Grid.ColumnSpan="2"/>
            <Button Text="X" Grid.Column="1"
                    CornerRadius="5" HeightRequest="36"
                    VerticalOptions="Start"
                    Command="{Binding ClearTokenCommand}"
                    IsVisible="{Binding IsClearTokenTextVisible}"/>
            <v:TokenView BindingContext="{Binding Token}"
                         Grid.ColumnSpan="2"
                         Grid.Row="1"/>
        </Grid>
    </ScrollView>
</ContentPage>
